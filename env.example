# Copy this file to .env and fill in real values.
# .env is already covered by .gitignore — never commit it.

DB_USER=ADMIN
DB_PASSWORD=your_db_password_here
DB_DSN=your_dsn_alias_here
DB_CONNECTION_STRING=your_full_oracle_connection_string_here
WALLET_LOCATION=./wallet
WALLET_PASSWORD=your_wallet_password_here
OCI_COMPARTMENT_ID=your_oci_tenancy_or_compartment_ocid_here
